# ══════════════════════════════════════════════════════════════
# Homebase — Environment Variables
# ══════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in the values.
# All variables are REQUIRED unless marked (optional).

# ── Turso Database ───────────────────────────────────────────
# 1. Install CLI:  curl -sSfL https://get.tur.so/install.sh | bash
# 2. Sign up:      turso auth signup
# 3. Create DB:    turso db create homebase
# 4. Get URL:      turso db show homebase --url
# 5. Create token: turso db tokens create homebase
TURSO_DATABASE_URL=libsql://your-database-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here

# ── Auth.js (NextAuth v5) ────────────────────────────────────
# Generate secret: npx auth secret
# AUTH_URL should be http://localhost:3000 locally,
# and your production URL (e.g. https://homebase.app) in Vercel.
AUTH_SECRET=generate-with-npx-auth-secret
AUTH_URL=http://localhost:3000

# ── Google OAuth ─────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add authorized redirect URI:
#    Local:  http://localhost:3000/api/auth/callback/google
#    Prod:   https://your-domain.com/api/auth/callback/google
AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-client-secret

# ── Resend (Email) ───────────────────────────────────────────
# Used for magic link sign-in AND email reminders/digests.
# 1. Sign up at https://resend.com
# 2. Get API key at https://resend.com/api-keys
# 3. Verify your sending domain at https://resend.com/domains
AUTH_RESEND_KEY=re_your_resend_api_key

# ── LemonSqueezy (Payments) ──────────────────────────────────
# Dashboard: https://app.lemonsqueezy.com
#
# Store ID: Settings → General → Store ID
LEMONSQUEEZY_STORE_ID=your_store_id

# API Key: Settings → API → Create API Key
LEMONSQUEEZY_API_KEY=your_api_key

# Webhook Secret:
# 1. Go to Settings → Webhooks → Create Webhook
# 2. Set URL to: https://your-domain.com/api/webhooks/lemonsqueezy
# 3. Select event: order_completed
# 4. Copy the Signing Secret
LEMONSQUEEZY_WEBHOOK_SECRET=your_webhook_signing_secret

# Checkout URL: Products → Your Product → Share → Checkout URL
# Server-side copy (used for /pricing redirect)
LEMONSQUEEZY_CHECKOUT_URL=https://your-store.lemonsqueezy.com/checkout/buy/...

# Public checkout URL (exposed to the browser for landing page CTAs)
# Must use NEXT_PUBLIC_ prefix to be available in client components
NEXT_PUBLIC_LEMONSQUEEZY_CHECKOUT_URL=https://your-store.lemonsqueezy.com/checkout/buy/...

# ── Cron Jobs ────────────────────────────────────────────────
# Protects /api/cron/* endpoints from unauthorized access.
# Vercel Cron automatically sends this as a Bearer token.
# Generate: openssl rand -base64 32
CRON_SECRET=your-cron-secret-here
